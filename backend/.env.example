# AutoMaintainer Backend Configuration

# ──────────────────────────────────────────────
# LLM Models — DashScope FREE Quota (Recommended)
# ──────────────────────────────────────────────
# All models below have 1M free tokens each. Enable "Free Quota Only" in
# the DashScope console to prevent any charges.
#
# Agent routing strategy (strongest models where it matters most):
#   developer     -> qwen3-max       (best reasoning for code generation)
#   reviewer      -> qwen-max        (strong analysis for code review)
#   qa_tester     -> qwen3.5-plus    (good reasoning for test generation)
#   architect     -> qwen3.5-plus    (planning and architecture)
#   issue_analyst -> qwen3.7-plus    (structured analysis, default model)
#   security      -> qwen3.5-122b    (efficient MoE for scanning)
#   documentation -> qwen3.5-122b    (lighter model for writing docs)

DASHSCOPE_API_KEY=your_dashscope_api_key_here

LLM_MODELS={"qwen3-max":{"api_key":"YOUR_KEY","model":"qwen3-max","base_url":"https://dashscope-intl.aliyuncs.com/compatible-mode/v1"},"qwen-max":{"api_key":"YOUR_KEY","model":"qwen-max","base_url":"https://dashscope-intl.aliyuncs.com/compatible-mode/v1"},"qwen3.7-plus":{"api_key":"YOUR_KEY","model":"qwen3.7-plus","base_url":"https://dashscope-intl.aliyuncs.com/compatible-mode/v1"},"qwen3.5-plus":{"api_key":"YOUR_KEY","model":"qwen3.5-plus-2026-02-15","base_url":"https://dashscope-intl.aliyuncs.com/compatible-mode/v1"},"qwen3.5-122b":{"api_key":"YOUR_KEY","model":"qwen3.5-122b-a10b","base_url":"https://dashscope-intl.aliyuncs.com/compatible-mode/v1"}}

DEFAULT_MODEL=qwen3.7-plus

AGENT_MODELS={"developer":"qwen3-max","reviewer":"qwen-max","architect":"qwen3.5-plus","issue_analyst":"qwen3.7-plus","qa_tester":"qwen3.5-plus","security":"qwen3.5-122b","documentation":"qwen3.5-122b"}

# Legacy single-model fallback (used when LLM_MODELS is empty)
# QWEN_MODEL=qwen-plus

# ──────────────────────────────────────────────
# GitHub
# ──────────────────────────────────────────────
GITHUB_TOKEN=your_github_token_here
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# ──────────────────────────────────────────────
# Database
# ──────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./automaintainer.db

# ──────────────────────────────────────────────
# Auth (ENABLED by default in production)
# ──────────────────────────────────────────────
AUTH_ENABLED=true
AUTH_TOKEN=change-me-to-a-secure-random-string

# ──────────────────────────────────────────────
# Server
# ──────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:3000

# ──────────────────────────────────────────────
# Sandbox
# ──────────────────────────────────────────────
SANDBOX_ENABLED=true
SANDBOX_TIMEOUT=30

# ──────────────────────────────────────────────
# Pipeline Limits
# ──────────────────────────────────────────────
MAX_CONCURRENT_PIPELINES=3
PIPELINE_TIMEOUT_SECONDS=600
MAX_REQUEST_SIZE_MB=10