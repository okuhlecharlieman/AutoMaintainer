# AutoMaintainer - Environment Variables
# Using DashScope FREE quota models (1M tokens each, enable "Free Quota Only")

DASHSCOPE_API_KEY=your_dashscope_api_key_here

# Multi-model config: 5 free models, routed per-agent for best results
LLM_MODELS={"qwen3-max":{"api_key":"YOUR_KEY","model":"qwen3-max","base_url":"https://dashscope-intl.aliyuncs.com/compatible-mode/v1"},"qwen-max":{"api_key":"YOUR_KEY","model":"qwen-max","base_url":"https://dashscope-intl.aliyuncs.com/compatible-mode/v1"},"qwen3.7-plus":{"api_key":"YOUR_KEY","model":"qwen3.7-plus","base_url":"https://dashscope-intl.aliyuncs.com/compatible-mode/v1"},"qwen3.5-plus":{"api_key":"YOUR_KEY","model":"qwen3.5-plus-2026-02-15","base_url":"https://dashscope-intl.aliyuncs.com/compatible-mode/v1"},"qwen3.5-122b":{"api_key":"YOUR_KEY","model":"qwen3.5-122b-a10b","base_url":"https://dashscope-intl.aliyuncs.com/compatible-mode/v1"}}

DEFAULT_MODEL=qwen3.7-plus

# Developer=qwen3-max, Reviewer=qwen-max, Architect/QA=qwen3.5-plus, Security/Docs=qwen3.5-122b
AGENT_MODELS={"developer":"qwen3-max","reviewer":"qwen-max","architect":"qwen3.5-plus","issue_analyst":"qwen3.7-plus","qa_tester":"qwen3.5-plus","security":"qwen3.5-122b","documentation":"qwen3.5-122b"}

# GitHub — needed for PR creation and repo context
GITHUB_TOKEN=your_github_token_here
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# Optional overrides
SANDBOX_ENABLED=true
SANDBOX_TIMEOUT=30

# Authentication — set ADMIN_PASSWORD to enable login, or AUTH_TOKEN for API-key access
AUTH_ENABLED=true
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-to-a-secure-password
AUTH_TOKEN=                          # Optional: static API key (also accepted alongside JWT)
JWT_SECRET=                          # Optional: if empty, derived from AUTH_TOKEN or ADMIN_PASSWORD
