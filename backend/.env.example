# AutoMaintainer Backend Configuration

# ──────────────────────────────────────────────
# LLM Models — FREE providers (choose one or mix)
# ──────────────────────────────────────────────
# GOOGLE GEMINI (recommended — free forever with rate limits)
#   Get API key: https://aistudio.google.com/apikey
#   Free: 15 RPM, ~1M tokens/min, 1500 requests/day
#
# GROQ (fast free tier)
#   Get API key: https://console.groq.com
#   Free: 30 RPM, 6000 tokens/min
#
# DashScope (1M free tokens per model, then paid)

# ── Option A: Google Gemini ───────────────────
LLM_MODELS={"gemini-flash":{"api_key":"YOUR_GOOGLE_KEY","model":"gemini-2.0-flash-001","base_url":"https://generativelanguage.googleapis.com/v1beta/openai/"},"gemini-2.5":{"api_key":"YOUR_GOOGLE_KEY","model":"gemini-2.5-flash-preview-05-20","base_url":"https://generativelanguage.googleapis.com/v1beta/openai/"}}
DEFAULT_MODEL=gemini-2.5
AGENT_MODELS={"developer":"gemini-2.5","reviewer":"gemini-2.5","architect":"gemini-flash","issue_analyst":"gemini-2.5","qa_tester":"gemini-flash","security":"gemini-flash","documentation":"gemini-flash"}

# ── Option B: Gemini + Groq mix ───────────────
# LLM_MODELS={"gemini-2.5":{"api_key":"YOUR_GOOGLE_KEY","model":"gemini-2.5-flash-preview-05-20","base_url":"https://generativelanguage.googleapis.com/v1beta/openai/"},"gemini-flash":{"api_key":"YOUR_GOOGLE_KEY","model":"gemini-2.0-flash-001","base_url":"https://generativelanguage.googleapis.com/v1beta/openai/"},"groq-llama":{"api_key":"YOUR_GROQ_KEY","model":"llama-3.3-70b-versatile","base_url":"https://api.groq.com/openai/v1"}}
# AGENT_MODELS={"developer":"gemini-2.5","reviewer":"gemini-2.5","qa_tester":"groq-llama","security":"groq-llama"}

# ── Option C: OpenRouter free models ──────────
#   Get API key: https://openrouter.ai
#   Free models with structured_output / response_format support:
#   nemotron-ultra: NVIDIA Nemotron 3 Ultra 550B — best for code generation (Developer agent)
#   owl-alpha: strong code gen, supports json_object mode
#   nex-n2-pro: MoE 397B total/17B active, supports json_object mode
#   gemma-4-31b: supports json_object mode, decent coding
# LLM_MODELS={"nemotron-ultra":{"api_key":"YOUR_OPENROUTER_KEY","model":"nvidia/nemotron-3-ultra-550b-a55b:free","base_url":"https://openrouter.ai/api/v1","max_tokens":32768},"openrouter-owl":{"api_key":"YOUR_OPENROUTER_KEY","model":"openrouter/owl-alpha","base_url":"https://openrouter.ai/api/v1","max_tokens":262144},"openrouter-nex":{"api_key":"YOUR_OPENROUTER_KEY","model":"nex-agi/nex-n2-pro:free","base_url":"https://openrouter.ai/api/v1","max_tokens":262144},"openrouter-gemma4":{"api_key":"YOUR_OPENROUTER_KEY","model":"google/gemma-4-31b-it:free","base_url":"https://openrouter.ai/api/v1","max_tokens":32768}}
# DEFAULT_MODEL=openrouter-owl
# AGENT_MODELS={"developer":"nemotron-ultra","reviewer":"openrouter-gemma4","architect":"openrouter-nex","issue_analyst":"openrouter-owl","qa_tester":"openrouter-nex","security":"openrouter-nex","documentation":"openrouter-nex"}

# ── Option D: DashScope (original) ────────────
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# ──────────────────────────────────────────────
# GitHub
# ──────────────────────────────────────────────
GITHUB_TOKEN=your_github_token_here
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# ──────────────────────────────────────────────
# Database
# ──────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./automaintainer.db

# ──────────────────────────────────────────────
# Auth (ENABLED by default in production)
# ──────────────────────────────────────────────
AUTH_ENABLED=true
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-to-a-secure-random-password
AUTH_TOKEN=                          # Optional: also accepted as static API key
JWT_SECRET=                          # Optional: derived from AUTH_TOKEN or ADMIN_PASSWORD if empty

# ──────────────────────────────────────────────
# Server
# ──────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:3000

# ──────────────────────────────────────────────
# Sandbox
# ──────────────────────────────────────────────
SANDBOX_ENABLED=true
SANDBOX_TIMEOUT=30

# ──────────────────────────────────────────────
# Pipeline Limits
# ──────────────────────────────────────────────
MAX_CONCURRENT_PIPELINES=3
PIPELINE_TIMEOUT_SECONDS=600
MAX_REQUEST_SIZE_MB=10