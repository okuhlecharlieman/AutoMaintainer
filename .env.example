# AutoMaintainer - Environment Variables

# ──────────────────────────────────────────────
# LLM Models — FREE providers (choose one or mix)
# ──────────────────────────────────────────────
# DashScope free quota is limited (1M tokens per model). When exhausted,
# switch to Google Gemini (generous free tier) or Groq (fast free tier).
#
# GOOGLE GEMINI (recommended — free forever with rate limits)
#   Get API key: https://aistudio.google.com/apikey
#   Free tier: 15 RPM, ~1M tokens/min, 1500 requests/day
#
# GROQ (fast free tier — good for simpler agent tasks)
#   Get API key: https://console.groq.com
#   Free tier: 30 RPM, 6000 tokens/min

# ── Option A: OpenRouter free models (recommended — zero cost, no quota limits) ──
#   Get API key: https://openrouter.ai/keys (free signup, no credit card)
#   Free models: nemotron-3-ultra (550B, best for code), owl-alpha, nex-n2-pro, gemma-4-31b
#   Free tier: rate-limited but no token quota cap
# Set OPENROUTER_API_KEY below and use these LLM_MODELS:
LLM_MODELS={"nemotron-ultra":{"api_key":"YOUR_OPENROUTER_KEY","model":"nvidia/nemotron-3-ultra-550b-a55b:free","base_url":"https://openrouter.ai/api/v1","max_tokens":32768},"openrouter-owl":{"api_key":"YOUR_OPENROUTER_KEY","model":"openrouter/owl-alpha","base_url":"https://openrouter.ai/api/v1","max_tokens":262144},"openrouter-nex":{"api_key":"YOUR_OPENROUTER_KEY","model":"nex-agi/nex-n2-pro:free","base_url":"https://openrouter.ai/api/v1","max_tokens":262144}}
DEFAULT_MODEL=openrouter-owl
AGENT_MODELS={"developer":"nemotron-ultra","reviewer":"openrouter-owl","architect":"openrouter-nex","issue_analyst":"openrouter-owl","qa_tester":"openrouter-nex","security":"openrouter-nex","documentation":"openrouter-nex"}

# ── Option B: Google Gemini (generous free tier — 1M tokens/min) ──────────
# Set GOOGLE_API_KEY below and use these LLM_MODELS:
# LLM_MODELS={"gemini-flash":{"api_key":"YOUR_GOOGLE_KEY","model":"gemini-2.0-flash-001","base_url":"https://generativelanguage.googleapis.com/v1beta/openai/"},"gemini-2.5":{"api_key":"YOUR_GOOGLE_KEY","model":"gemini-2.5-flash-preview-05-20","base_url":"https://generativelanguage.googleapis.com/v1beta/openai/"}}
# DEFAULT_MODEL=gemini-2.5
# AGENT_MODELS={"developer":"gemini-2.5","reviewer":"gemini-2.5","architect":"gemini-flash","issue_analyst":"gemini-2.5","qa_tester":"gemini-flash","security":"gemini-flash","documentation":"gemini-flash"}

# ── Option C: Gemini + Groq mix (Gemini for heavy tasks, Groq for fast ones) ──
# Set both GOOGLE_API_KEY and GROQ_API_KEY below:
# LLM_MODELS={"gemini-2.5":{"api_key":"YOUR_GOOGLE_KEY","model":"gemini-2.5-flash-preview-05-20","base_url":"https://generativelanguage.googleapis.com/v1beta/openai/"},"gemini-flash":{"api_key":"YOUR_GOOGLE_KEY","model":"gemini-2.0-flash-001","base_url":"https://generativelanguage.googleapis.com/v1beta/openai/"},"groq-llama":{"api_key":"YOUR_GROQ_KEY","model":"llama-3.3-70b-versatile","base_url":"https://api.groq.com/openai/v1"}}
# DEFAULT_MODEL=gemini-2.5
# AGENT_MODELS={"developer":"gemini-2.5","reviewer":"gemini-2.5","architect":"gemini-flash","issue_analyst":"gemini-2.5","qa_tester":"groq-llama","security":"groq-llama","documentation":"gemini-flash"}

# ── Option D: DashScope (original — free quota exhausted, 1M tokens per model) ──
# Set DASHSCOPE_API_KEY below:
# LLM_MODELS={"qwen3-max":{"api_key":"YOUR_KEY","model":"qwen3-max","base_url":"https://dashscope-intl.aliyuncs.com/compatible-mode/v1"},...}
# DEFAULT_MODEL=qwen3.7-plus

# GitHub — needed for PR creation and repo context
GITHUB_TOKEN=your_github_token_here
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# GitHub OAuth — register an OAuth App at https://github.com/settings/applications
# Callback URL should be: https://<your-backend-url>/api/auth/github/callback
GITHUB_OAUTH_CLIENT_ID=your_github_oauth_client_id
GITHUB_OAUTH_CLIENT_SECRET=your_github_oauth_client_secret
GITHUB_OAUTH_REDIRECT_URI=https://your-backend-url/api/auth/github/callback

# Frontend URL — where to redirect users after GitHub OAuth login
FRONTEND_URL=https://your-frontend-url

# Optional overrides
SANDBOX_ENABLED=true
SANDBOX_TIMEOUT=30

# Authentication — set ADMIN_PASSWORD to enable login, or AUTH_TOKEN for API-key access
AUTH_ENABLED=true
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-to-a-secure-password
AUTH_TOKEN=                          # Optional: static API key (also accepted alongside JWT)
JWT_SECRET=                          # Optional: if empty, derived from AUTH_TOKEN or ADMIN_PASSWORD
