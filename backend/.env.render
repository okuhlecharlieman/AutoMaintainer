# AutoMaintainer Backend Environment Variables for Render
# Copy your actual values from .env — this is a template for Render env vars

# LLM: OpenRouter free models
# Nemotron 3 Ultra (550B) is the Developer agent — best code generation
# NOTE: qwen3-coder removed due to persistent rate limits on free tier
LLM_MODELS={"nemotron-ultra":{"api_key":"YOUR_OPENROUTER_KEY","model":"nvidia/nemotron-3-ultra-550b-a55b:free","base_url":"https://openrouter.ai/api/v1","max_tokens":32768},"nemotron-super":{"api_key":"YOUR_OPENROUTER_KEY","model":"nvidia/nemotron-3-super-120b-a12b:free","base_url":"https://openrouter.ai/api/v1","max_tokens":32768},"north-code":{"api_key":"YOUR_OPENROUTER_KEY","model":"cohere/north-mini-code:free","base_url":"https://openrouter.ai/api/v1","max_tokens":32768},"laguna":{"api_key":"YOUR_OPENROUTER_KEY","model":"poolside/laguna-m.1:free","base_url":"https://openrouter.ai/api/v1","max_tokens":32768}}
DEFAULT_MODEL=nemotron-super
AGENT_MODELS={"developer":"nemotron-ultra","reviewer":"nemotron-super","architect":"nemotron-super","issue_analyst":"nemotron-super","qa_tester":"north-code","security":"north-code","documentation":"laguna"}

GITHUB_TOKEN=your_github_token_here
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# Database URL (Render provides PostgreSQL by default, but we'll use SQLite)
DATABASE_URL=sqlite+aiosqlite:///./automaintainer.db


# CORS - allow frontend origin
CORS_ORIGINS=https://automaintainer-frontend.onrender.com,https://automaintainer-frontend.vercel.app,http://localhost:3000

# Pipeline limits (Render free tier has constrained resources)
MAX_CONCURRENT_PIPELINES=2
PIPELINE_TIMEOUT_SECONDS=600
MAX_REQUEST_SIZE_MB=10

# Agent timeouts — Developer gets 5 min for large model code gen
AGENT_TIMEOUT_DEFAULT=120
AGENT_TIMEOUT_DEVELOPER=420

# Server configuration
HOST=0.0.0.0
PORT=10000
