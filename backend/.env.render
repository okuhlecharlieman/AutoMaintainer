# AutoMaintainer Backend Environment Variables for Render
# Copy your actual values from .env — this is a template for Render env vars

# LLM: OpenRouter free models (DashScope quota exhausted)
LLM_MODELS={"openrouter-free":{"api_key":"YOUR_OPENROUTER_KEY","model":"meta-llama/llama-3.1-8b-instruct:free","base_url":"https://openrouter.ai/api/v1"},"openrouter-qwen":{"api_key":"YOUR_OPENROUTER_KEY","model":"qwen/qwen-2-7b-instruct:free","base_url":"https://openrouter.ai/api/v1"},"openrouter-deepseek":{"api_key":"YOUR_OPENROUTER_KEY","model":"deepseek/deepseek-r1-7b:free","base_url":"https://openrouter.ai/api/v1"},"openrouter-gemma":{"api_key":"YOUR_OPENROUTER_KEY","model":"google/gemma-2-9b-it:free","base_url":"https://openrouter.ai/api/v1"}}
DEFAULT_MODEL=openrouter-qwen
AGENT_MODELS={"developer":"openrouter-qwen","reviewer":"openrouter-gemma","architect":"openrouter-free","issue_analyst":"openrouter-deepseek","qa_tester":"openrouter-free","security":"openrouter-free","documentation":"openrouter-free"}

GITHUB_TOKEN=your_github_token_here
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# Database URL (Render provides PostgreSQL by default, but we'll use SQLite)
DATABASE_URL=sqlite+aiosqlite:///./automaintainer.db


# CORS - allow frontend origin
CORS_ORIGINS=https://automaintainer-frontend.onrender.com,https://automaintainer-frontend.vercel.app,http://localhost:3000

# Pipeline limits (Render free tier has constrained resources)
MAX_CONCURRENT_PIPELINES=2
PIPELINE_TIMEOUT_SECONDS=600
MAX_REQUEST_SIZE_MB=10

# Server configuration
HOST=0.0.0.0
PORT=10000
