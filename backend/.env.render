# AutoMaintainer Backend Environment Variables for Render
# Copy your actual values from .env file

DASHSCOPE_API_KEY=your_dashscope_api_key_here
GITHUB_TOKEN=your_github_token_here
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# Default model configuration
DEFAULT_MODEL=qwen3.7-plus

LLM_MODELS={"qwen3-max":{"api_key":"your_dashscope_api_key_here","model":"qwen3-max","base_url":"https://dashscope-intl.aliyuncs.com/compatible-mode/v1"},"qwen-max":{"api_key":"your_dashscope_api_key_here","model":"qwen-max","base_url":"https://dashscope-intl.aliyuncs.com/compatible-mode/v1"},"qwen3.7-plus":{"api_key":"your_dashscope_api_key_here","model":"qwen3.7-plus","base_url":"https://dashscope-intl.aliyuncs.com/compatible-mode/v1"},"qwen3.5-plus":{"api_key":"your_dashscope_api_key_here","model":"qwen3.5-plus-2026-02-15","base_url":"https://dashscope-intl.aliyuncs.com/compatible-mode/v1"},"qwen3.5-122b":{"api_key":"your_dashscope_api_key_here","model":"qwen3.5-122b-a10b","base_url":"https://dashscope-intl.aliyuncs.com/compatible-mode/v1"}}

AGENT_MODELS={"developer":"qwen3-max","reviewer":"qwen-max","architect":"qwen3.5-plus","issue_analyst":"qwen3.7-plus","qa_tester":"qwen3.5-plus","security":"qwen3.5-122b","documentation":"qwen3.5-122b"}

# Database URL (Render provides PostgreSQL by default, but we'll use SQLite)
DATABASE_URL=sqlite+aiosqlite:///./automaintainer.db

# Auth (Render deployments should always have auth enabled)
AUTH_ENABLED=true
AUTH_TOKEN=change-me-to-a-secure-random-string

# CORS - allow frontend origin
CORS_ORIGINS=https://automaintainer-frontend.onrender.com,https://automaintainer-frontend.vercel.app,http://localhost:3000

# Pipeline limits (Render free tier has constrained resources)
MAX_CONCURRENT_PIPELINES=2
PIPELINE_TIMEOUT_SECONDS=600
MAX_REQUEST_SIZE_MB=10

# Server configuration
HOST=0.0.0.0
PORT=10000