# AutoMaintainer Backend Environment Variables for Render
# Copy your actual values from .env — this is a template for Render env vars

# LLM: OpenRouter free models (DashScope quota exhausted)
LLM_MODELS={"openrouter-owl":{"api_key":"YOUR_OPENROUTER_KEY","model":"openrouter/owl-alpha","base_url":"https://openrouter.ai/api/v1","max_tokens":262144},"openrouter-nex":{"api_key":"YOUR_OPENROUTER_KEY","model":"nex-agi/nex-n2-pro:free","base_url":"https://openrouter.ai/api/v1","max_tokens":262144},"openrouter-gemma4":{"api_key":"YOUR_OPENROUTER_KEY","model":"google/gemma-4-31b-it:free","base_url":"https://openrouter.ai/api/v1","max_tokens":32768}}
DEFAULT_MODEL=openrouter-owl
AGENT_MODELS={"developer":"openrouter-owl","reviewer":"openrouter-gemma4","architect":"openrouter-nex","issue_analyst":"openrouter-owl","qa_tester":"openrouter-nex","security":"openrouter-nex","documentation":"openrouter-nex"}

GITHUB_TOKEN=your_github_token_here
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# Database URL (Render provides PostgreSQL by default, but we'll use SQLite)
DATABASE_URL=sqlite+aiosqlite:///./automaintainer.db


# CORS - allow frontend origin
CORS_ORIGINS=https://automaintainer-frontend.onrender.com,https://automaintainer-frontend.vercel.app,http://localhost:3000

# Pipeline limits (Render free tier has constrained resources)
MAX_CONCURRENT_PIPELINES=2
PIPELINE_TIMEOUT_SECONDS=600
MAX_REQUEST_SIZE_MB=10

# Server configuration
HOST=0.0.0.0
PORT=10000
